        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const currentRefreshToken = pm.environment.get('refreshToken');",
                  "if (!currentRefreshToken) {",
                  "  throw new Error('refreshToken is empty. Run Verify OTP or Login first.');",
                  "}",
                  "pm.variables.set('previousRefreshToken', currentRefreshToken);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Response contains token pair', function () {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.tokenType).to.eql('Bearer');",
                  "});",
                  "const previousRefreshToken = pm.variables.get('previousRefreshToken');",
                  "if (previousRefreshToken) {",
                  "  pm.test('Refresh token is rotated', function () {",
                  "    pm.expect(body.refreshToken).to.not.eql(previousRefreshToken);",
                  "  });",
                  "}",
                  "if (body.accessToken) pm.environment.set('accessToken', body.accessToken);",
                  "if (body.refreshToken) pm.environment.set('refreshToken', body.refreshToken);",
                  "if (body.tokenType) pm.environment.set('tokenType', body.tokenType);"
                ]
              }
            }
          ],
